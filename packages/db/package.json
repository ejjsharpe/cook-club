{
  "name": "@repo/db",
  "version": "1.0.0",
  "main": "index.ts",
  "exports": {
    ".": "./index.ts",
    "./schemas": "./schemas/index.ts",
    "./services": "./services/index.ts",
    "./utils": "./utils/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "check-types": "tsc --noEmit",
    "generate": "dotenvx run -- drizzle-kit generate",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\"",
    "migrate": "dotenvx run -- drizzle-kit migrate",
    "migrate:prod": "dotenvx run -f .env.production -- drizzle-kit migrate",
    "push": "dotenvx run -- drizzle-kit push",
    "push:prod": "dotenvx run -f .env.production -- drizzle-kit push",
    "seed": "dotenvx run -- bun run seed.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "latest",
    "@repo/contracts": "workspace:*",
    "@repo/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "0.44.3"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.34.0",
    "@cloudflare/workers-types": "^4.20250718.0",
    "@repo/tsconfig": "workspace:*",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^3.0.0",
    "eslint-config-universe": "15.0.3",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.8.3"
  },
  "eslintConfig": {
    "extends": "universe/node"
  },
  "nx": {
    "tags": ["type:package", "scope:db"]
  }
}
