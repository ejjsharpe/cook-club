{
  "name": "cookclub-api",
  "exports": {
    "./service-types": "./src/service-types.ts"
  },
  "scripts": {
    "dev": "wait-on tcp:8788 && wait-on tcp:8789 && wrangler dev --ip 0.0.0.0 --inspector-port 9229",
    "build": "tsc --noEmit",
    "deploy": "wrangler deploy --minify",
    "check-types": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/trpc-server": "^0.4.0",
    "@repo/auth": "workspace:*",
    "@repo/contracts": "workspace:*",
    "@repo/db": "workspace:*",
    "@repo/trpc": "workspace:*",
    "hono": "^4.10.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.11.0",
    "@cloudflare/workers-types": "^4.20250718.0",
    "@repo/tsconfig": "workspace:*",
    "@types/node": "^24.0.14",
    "eslint-config-universe": "15.0.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3",
    "wait-on": "^9.0.3",
    "wrangler": "^4.50.0"
  },
  "eslintConfig": {
    "extends": "universe/node"
  },
  "nx": {
    "tags": ["type:app", "runtime:worker"]
  }
}
